<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" version="21.0.0">
  <diagram id="gt-process" name="Independent Ground Truth Process">
    <mxGraphModel dx="1422" dy="762" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ═══════════════════════════════════════════════════════════
             TITLE
        ═══════════════════════════════════════════════════════════ -->
        <mxCell id="2"
          value="Independent Ground Truth Generation — How Similarity Scores Are Computed"
          style="text;html=1;strokeColor=none;fillColor=#023d7a;align=center;verticalAlign=middle;rounded=1;fontStyle=1;fontSize=15;fontColor=#ffffff;"
          vertex="1" parent="1">
          <mxGeometry x="60" y="10" width="1280" height="46" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════
             INPUTS
        ═══════════════════════════════════════════════════════════ -->
        <mxCell id="3"
          value="&lt;b&gt;Query Dataset&lt;/b&gt;&lt;br/&gt;A CSV file from the datalake"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=0;"
          vertex="1" parent="1">
          <mxGeometry x="100" y="80" width="220" height="60" as="geometry" />
        </mxCell>

        <mxCell id="4"
          value="&lt;b&gt;Candidate Dataset&lt;/b&gt;&lt;br/&gt;A CSV file from the datalake"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=0;"
          vertex="1" parent="1">
          <mxGeometry x="1080" y="80" width="220" height="60" as="geometry" />
        </mxCell>

        <mxCell id="5"
          value="All dataset pairs in the datalake are scored (~160 × 160 combinations, self-pairs excluded)"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;"
          vertex="1" parent="1">
          <mxGeometry x="370" y="92" width="660" height="36" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════
             STEP 1 — COLUMN SIGNATURE EXTRACTION
        ═══════════════════════════════════════════════════════════ -->
        <!-- Background -->
        <mxCell id="6"
          value=""
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffde7;strokeColor=#f9a825;"
          vertex="1" parent="1">
          <mxGeometry x="60" y="165" width="1280" height="230" as="geometry" />
        </mxCell>

        <!-- Section label -->
        <mxCell id="7"
          value="STEP 1 — Extract a Column Signature for every column in each dataset"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=1;fontSize=13;"
          vertex="1" parent="1">
          <mxGeometry x="60" y="167" width="1280" height="28" as="geometry" />
        </mxCell>

        <!-- Query signatures box -->
        <mxCell id="8"
          value="&lt;b&gt;Query — Column Signatures&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;One signature per column, containing:&lt;br/&gt;&lt;br/&gt;&lt;b&gt;top_values&lt;/b&gt; — the 20 most frequent non-null values&lt;br/&gt;(lowercased strings, stored as a set)&lt;br/&gt;&lt;b&gt;inferred_type&lt;/b&gt; — &apos;numeric&apos; or &apos;string&apos;&lt;br/&gt;&lt;b&gt;cardinality_ratio&lt;/b&gt; — unique values / total rows&lt;br/&gt;&lt;b&gt;null_ratio&lt;/b&gt; — fraction of missing values&lt;br/&gt;&lt;b&gt;entropy&lt;/b&gt; — spread of the value distribution (bits)&lt;br/&gt;&lt;b&gt;numeric_stats&lt;/b&gt; — min, max, mean, std, p25, p50, p75"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#f9a825;align=left;fontSize=11;verticalAlign=top;"
          vertex="1" parent="1">
          <mxGeometry x="80" y="200" width="420" height="180" as="geometry" />
        </mxCell>

        <!-- Center note -->
        <mxCell id="9"
          value="Same extraction&lt;br/&gt;applied to both datasets"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;"
          vertex="1" parent="1">
          <mxGeometry x="555" y="272" width="290" height="44" as="geometry" />
        </mxCell>

        <!-- Candidate signatures box -->
        <mxCell id="10"
          value="&lt;b&gt;Candidate — Column Signatures&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;One signature per column, containing:&lt;br/&gt;&lt;br/&gt;&lt;b&gt;top_values&lt;/b&gt; — the 20 most frequent non-null values&lt;br/&gt;(lowercased strings, stored as a set)&lt;br/&gt;&lt;b&gt;inferred_type&lt;/b&gt; — &apos;numeric&apos; or &apos;string&apos;&lt;br/&gt;&lt;b&gt;cardinality_ratio&lt;/b&gt; — unique values / total rows&lt;br/&gt;&lt;b&gt;null_ratio&lt;/b&gt; — fraction of missing values&lt;br/&gt;&lt;b&gt;entropy&lt;/b&gt; — spread of the value distribution (bits)&lt;br/&gt;&lt;b&gt;numeric_stats&lt;/b&gt; — min, max, mean, std, p25, p50, p75"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#f9a825;align=left;fontSize=11;verticalAlign=top;"
          vertex="1" parent="1">
          <mxGeometry x="900" y="200" width="420" height="180" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════
             MERGE POINT — All column pairs
        ═══════════════════════════════════════════════════════════ -->
        <mxCell id="11"
          value="All column pairs (query_col × candidate_col) are compared"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#666666;fontSize=11;fontStyle=2;"
          vertex="1" parent="1">
          <mxGeometry x="490" y="420" width="420" height="38" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════
             STEP 2A — JOIN SCORING
        ═══════════════════════════════════════════════════════════ -->
        <!-- Background -->
        <mxCell id="12"
          value=""
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#4caf50;"
          vertex="1" parent="1">
          <mxGeometry x="60" y="480" width="580" height="300" as="geometry" />
        </mxCell>

        <!-- Header -->
        <mxCell id="13"
          value="JOIN SCORING"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=1;fontSize=14;fontColor=#2e7d32;"
          vertex="1" parent="1">
          <mxGeometry x="60" y="483" width="580" height="28" as="geometry" />
        </mxCell>

        <!-- Content -->
        <mxCell id="14"
          value="&lt;b&gt;Goal:&lt;/b&gt; Can we JOIN these two tables on a shared key (equi-join)?&lt;br/&gt;&lt;br/&gt;For each column pair (col_q, col_c):&lt;br/&gt;&lt;br/&gt;&lt;b&gt;① Skip&lt;/b&gt; if types differ (string ≠ numeric)&lt;br/&gt;&lt;br/&gt;&lt;b&gt;② Skip numeric&lt;/b&gt; columns if cardinality &gt; 5%&lt;br/&gt;&amp;nbsp;&amp;nbsp;Continuous values (prices, GPS, measurements) are not&lt;br/&gt;&amp;nbsp;&amp;nbsp;valid join keys. Only discrete numerics are kept&lt;br/&gt;&amp;nbsp;&amp;nbsp;(zip codes, years, category codes, IDs).&lt;br/&gt;&lt;br/&gt;&lt;b&gt;③ Compute containment:&lt;/b&gt;&lt;br/&gt;&amp;nbsp;&amp;nbsp;score = |top_q ∩ top_c| / |top_q|&lt;br/&gt;&amp;nbsp;&amp;nbsp;= fraction of query&apos;s top-20 values found in candidate&lt;br/&gt;&lt;br/&gt;&lt;b&gt;join_score = MAX across all valid column pairs&lt;/b&gt;&lt;br/&gt;A single joinable column pair is sufficient."
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f8e9;strokeColor=#4caf50;align=left;fontSize=11;verticalAlign=top;"
          vertex="1" parent="1">
          <mxGeometry x="75" y="514" width="550" height="254" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════
             STEP 2B — UNION SCORING
        ═══════════════════════════════════════════════════════════ -->
        <!-- Background -->
        <mxCell id="15"
          value=""
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#ff9800;"
          vertex="1" parent="1">
          <mxGeometry x="760" y="480" width="580" height="300" as="geometry" />
        </mxCell>

        <!-- Header -->
        <mxCell id="16"
          value="UNION SCORING"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=1;fontSize=14;fontColor=#e65100;"
          vertex="1" parent="1">
          <mxGeometry x="760" y="483" width="580" height="28" as="geometry" />
        </mxCell>

        <!-- Content -->
        <mxCell id="17"
          value="&lt;b&gt;Goal:&lt;/b&gt; Can we UNION these tables? (stack rows — same schema &amp;amp; domain)&lt;br/&gt;&lt;br/&gt;&lt;b&gt;① Build m×n column similarity matrix&lt;/b&gt; (no column names used):&lt;br/&gt;&amp;nbsp;&amp;nbsp;String × String: 0.55 × Jaccard(top_k) + 0.25 × type_match&lt;br/&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;+ 0.10 × cardinality_sim + 0.10 × entropy_sim&lt;br/&gt;&amp;nbsp;&amp;nbsp;Numeric × Numeric: 0.85 × dist_sim + 0.15 × cardinality_sim&lt;br/&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;dist_sim = 0.40 × range_overlap + 0.25 × mean_sim&lt;br/&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;+ 0.20 × spread_sim + 0.15 × entropy_sim&lt;br/&gt;&amp;nbsp;&amp;nbsp;Mixed (string × numeric): 0.0 — incompatible types&lt;br/&gt;&lt;br/&gt;&lt;b&gt;② Hungarian algorithm&lt;/b&gt; — globally optimal one-to-one alignment&lt;br/&gt;&amp;nbsp;&amp;nbsp;Finds the column pairing that maximises total similarity.&lt;br/&gt;&amp;nbsp;&amp;nbsp;Each column is matched at most once.&lt;br/&gt;&lt;br/&gt;&lt;b&gt;③ union_score = mean(aligned similarities) × coverage&lt;/b&gt;&lt;br/&gt;&amp;nbsp;&amp;nbsp;coverage = min(m,n) / max(m,n) &amp;nbsp;← penalises mismatched widths"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8f0;strokeColor=#ff9800;align=left;fontSize=11;verticalAlign=top;"
          vertex="1" parent="1">
          <mxGeometry x="775" y="514" width="550" height="254" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════
             SCORES
        ═══════════════════════════════════════════════════════════ -->
        <mxCell id="18"
          value="&lt;b&gt;join_score&lt;/b&gt; ∈ [0, 1]&lt;br/&gt;&lt;i&gt;is_join_gt = 1 if ≥ 0.15&lt;/i&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#4caf50;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="110" y="806" width="390" height="52" as="geometry" />
        </mxCell>

        <mxCell id="19"
          value="&lt;b&gt;union_score&lt;/b&gt; ∈ [0, 1]&lt;br/&gt;&lt;i&gt;is_union_gt = 1 if ≥ 0.20&lt;/i&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#ff9800;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="900" y="806" width="390" height="52" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════
             COMBINED SCORE
        ═══════════════════════════════════════════════════════════ -->
        <mxCell id="20"
          value="&lt;b&gt;combined_score = max( join_score , union_score )&lt;/b&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="440" y="892" width="520" height="46" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════
             OUTPUT
        ═══════════════════════════════════════════════════════════ -->
        <mxCell id="21"
          value="&lt;b&gt;Output CSV — one row per dataset pair&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;query_table &amp;nbsp;|&amp;nbsp; candidate_table &amp;nbsp;|&amp;nbsp; similarity &amp;nbsp;|&amp;nbsp; joinability &amp;nbsp;|&amp;nbsp; unionability &amp;nbsp;|&amp;nbsp; &lt;b&gt;is_join_gt&lt;/b&gt; &amp;nbsp;|&amp;nbsp; &lt;b&gt;is_union_gt&lt;/b&gt; &amp;nbsp;|&amp;nbsp; &lt;b&gt;is_ground_truth&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;&lt;b&gt;is_ground_truth = 1&lt;/b&gt; &amp;nbsp;when&amp;nbsp; is_join_gt = 1 &amp;nbsp;&lt;b&gt;OR&lt;/b&gt;&amp;nbsp; is_union_gt = 1"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="330" y="970" width="740" height="88" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════
             LEGEND
        ═══════════════════════════════════════════════════════════ -->
        <mxCell id="22"
          value="&lt;b&gt;Legend&lt;/b&gt;&lt;br/&gt;Containment(A,B) = |A ∩ B| / |A|&lt;br/&gt;Jaccard(A,B) = |A ∩ B| / |A ∪ B|&lt;br/&gt;Entropy = −Σ p·log₂(p)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;"
          vertex="1" parent="1">
          <mxGeometry x="60" y="970" width="230" height="88" as="geometry" />
        </mxCell>

        <mxCell id="23"
          value="&lt;b&gt;Why top-20 frequent values?&lt;/b&gt;&lt;br/&gt;Join keys and shared domains are characterised&lt;br/&gt;by their common values, not rare ones.&lt;br/&gt;Deterministic and distribution-aware."
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;"
          vertex="1" parent="1">
          <mxGeometry x="1110" y="970" width="230" height="88" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════
             EDGES
        ═══════════════════════════════════════════════════════════ -->

        <!-- Query CSV → Query Signatures -->
        <mxCell id="30"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="3" target="8" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Candidate CSV → Candidate Signatures -->
        <mxCell id="31"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="4" target="10" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Query Signatures → Merge point -->
        <mxCell id="32"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="8" target="11" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Candidate Signatures → Merge point -->
        <mxCell id="33"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="10" target="11" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Merge → Join scoring -->
        <mxCell id="34"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="11" target="14" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Merge → Union scoring -->
        <mxCell id="35"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="11" target="17" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Join content → join_score -->
        <mxCell id="36"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="14" target="18" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Union content → union_score -->
        <mxCell id="37"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="17" target="19" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- join_score → combined -->
        <mxCell id="38"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="18" target="20" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- union_score → combined -->
        <mxCell id="39"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" source="19" target="20" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- combined → output -->
        <mxCell id="40"
          style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" source="20" target="21" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
